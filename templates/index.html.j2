<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #1a1a2e;
            color: #e0e0e0;
            min-height: 100vh;
        }
        header {
            background: #16213e;
            padding: 1.5rem;
            text-align: center;
            border-bottom: 2px solid #0f3460;
        }
        header h1 { color: #e94560; font-size: 1.8rem; }
        header p { color: #999; margin-top: 0.3rem; font-size: 0.9rem; }
        .stats {
            display: flex;
            justify-content: center;
            gap: 2rem;
            padding: 1rem;
            background: #16213e;
            border-bottom: 1px solid #0f3460;
        }
        .stats span { font-size: 0.9rem; color: #aaa; }
        .stats strong { color: #e94560; }
        .deals {
            max-width: 1000px;
            margin: 1.5rem auto;
            padding: 0 1rem;
            display: grid;
            gap: 1rem;
        }
        .deal {
            background: #16213e;
            border-radius: 8px;
            padding: 1.2rem;
            border: 1px solid #0f3460;
            transition: border-color 0.2s;
        }
        .deal:hover { border-color: #e94560; }
        .deal-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
        }
        .deal-title {
            font-size: 1.05rem;
            font-weight: 600;
            color: #fff;
            flex: 1;
        }
        .deal-title a { color: #fff; text-decoration: none; }
        .deal-title a:hover { color: #e94560; }
        .discount-badge {
            background: #e94560;
            color: #fff;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            font-weight: 700;
            font-size: 0.9rem;
            white-space: nowrap;
        }
        .deal-meta {
            display: flex;
            gap: 1.5rem;
            margin-top: 0.6rem;
            font-size: 0.85rem;
            color: #999;
            flex-wrap: wrap;
        }
        .deal-meta .price {
            color: #4ecca3;
            font-weight: 600;
        }
        .deal-meta .original-price {
            text-decoration: line-through;
            color: #666;
        }
        .deal-meta .retailer { color: #aaa; }
        footer {
            text-align: center;
            padding: 2rem;
            color: #555;
            font-size: 0.8rem;
        }
        @media (max-width: 600px) {
            .deal-header { flex-direction: column; }
            .deal-meta { gap: 0.8rem; }
        }
    </style>
</head>
<body>
    <header>
        <h1>{{ title }}</h1>
        <p>Updated {{ generated_at }}</p>
    </header>
    <div class="stats">
        <span><strong>{{ total_deals }}</strong> active deals</span>
    </div>
    <div class="deals">
        {% for deal in deals %}
        <div class="deal">
            <div class="deal-header">
                <div class="deal-title">
                    <a href="{{ deal.url }}" target="_blank" rel="noopener">{{ deal.game_name or deal.title }}</a>
                </div>
                {% if deal.discount_pct %}
                <span class="discount-badge">-{{ deal.discount_pct | round(0) | int }}%</span>
                {% endif %}
            </div>
            <div class="deal-meta">
                {% if deal.sale_price %}
                <span class="price">${{ "%.2f" | format(deal.sale_price) }}</span>
                {% endif %}
                {% if deal.original_price %}
                <span class="original-price">${{ "%.2f" | format(deal.original_price) }}</span>
                {% endif %}
                <span class="retailer">{{ deal.retailer or 'Unknown' }}</span>
                {% if deal.posted_at %}
                <span>{{ deal.posted_at[:10] }}</span>
                {% endif %}
            </div>
        </div>
        {% else %}
        <div class="deal" style="text-align:center; color:#666;">
            No active deals found. Check back soon!
        </div>
        {% endfor %}
    </div>
    <footer>
        Deals sourced from r/boardgamedeals | Generated {{ generated_at }}
    </footer>
</body>
</html>
